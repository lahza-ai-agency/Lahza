# Client-side (exposed to the browser bundle — anon/publishable key only)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Server-side (SSR / server functions — same project, plain names, never VITE_-prefixed)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# Server-side ONLY — service role key, bypasses RLS.
# Never prefix this with VITE_. Never expose it to client code.
# Set this in your hosting provider's dashboard (e.g. Vercel → Project → Settings → Environment Variables),
# not just in a local .env file, for it to work in production.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
